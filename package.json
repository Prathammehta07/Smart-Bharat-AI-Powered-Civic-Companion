{
  "name": "smart-bharat-monorepo",
  "version": "1.0.0",
  "description": "Smart Bharat - AI-Powered Civic Companion",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "start": "concurrently \"npm run start --workspace=backend\" \"npm run start --workspace=frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
